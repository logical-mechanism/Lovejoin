{
  "name": "lovejoin",
  "private": true,
  "version": "0.2.0",
  "description": "Sigmajoin privacy mixer on Cardano. Hyperstructure.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --filter ./offchain --filter ./backend --filter ./ui run build",
    "test": "pnpm -r --filter ./offchain --filter ./backend --filter ./ui run test",
    "lint": "pnpm -r --filter ./offchain --filter ./backend --filter ./ui --filter ./integration-tests --filter ./stress-tests run lint && prettier --check .",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "format": "prettier --write . && eslint . --fix",
    "typecheck": "pnpm -r --filter ./offchain --filter ./backend --filter ./ui --filter ./integration-tests run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
