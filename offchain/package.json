{
  "name": "@lovejoin/sdk",
  "version": "0.3.0",
  "description": "Lovejoin Sigmajoin SDK: prover, tx builder, CIP-30, collateral provider client.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "lovejoin": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && eslint .",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cli": "tsx src/cli/index.ts",
    "docs:sdk": "typedoc",
    "gen:parity": "tsx scripts/gen-encoding-parity.ts",
    "gen:f4-regression": "tsx scripts/gen-f4-regression.ts",
    "gen:schnorr-kat": "tsx scripts/gen-schnorr-kat.ts",
    "gen:dhtuple-kat": "tsx scripts/gen-dhtuple-kat.ts",
    "gen:sigmaor-kat": "tsx scripts/gen-sigmaor-kat.ts",
    "gen:negative-kat": "tsx scripts/gen-negative-kat.ts",
    "gen:kat": "tsx scripts/gen-schnorr-kat.ts && tsx scripts/gen-dhtuple-kat.ts && tsx scripts/gen-sigmaor-kat.ts && tsx scripts/gen-negative-kat.ts"
  },
  "dependencies": {
    "@meshsdk/core": "1.8.14",
    "@meshsdk/core-csl": "1.8.14",
    "@meshsdk/core-cst": "1.8.14",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "cbor-x": "1.6.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
