node_modules/
dist/
build/
.cache/
.pnpm-store/

# TypeScript
*.tsbuildinfo

# Vite / UI
ui/dist/
ui/.vite/

# Build-time mirror of the whitepaper PDFs. Source of truth is
# `papers/` at the repo root; ui/scripts/copy-papers.mjs copies them
# into ui/public/papers/ so vite bundles them under /papers/*.pdf.
ui/public/papers/

# Aiken
contracts/build/
contracts/.build/
contracts/plutus.json

# Rust — Cargo.lock IS committed for reproducible KAT cross-checks
# (see docs/spec/12-build-guide.md §"Reproducibility").
crypto/ref/target/

# Local secrets / env
.env
.env.local
*.skey
*.vkey

# Local DO App Platform spec — committed `.do/app.yaml` carries
# placeholders for SECRET env vars (OGMIOS_URL, DBSYNC_URL, etc.); a
# local copy with real values can live next to it as `*.local.yaml`
# and never reaches the repo. See docs/deploy.md §"Secrets handling".
.do/*.local.yaml

# Bootstrap wallets — recommended location for the per-network wallet files
# (payment.skey/vkey, payment.addr) used by infra/bootstrap/*.sh. The bootstrap
# scripts only ever read these via env vars, but keeping the conventional path
# gitignored avoids accidents.
infra/bootstrap/wallets/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test artifacts
coverage/
playwright-report/
test-results/

# Generated documentation (issue #41).
# typedoc HTML for the SDK; CI / local devs regenerate via
# `pnpm --filter @lovejoin/sdk run docs:sdk`. OpenAPI 3 snapshot for
# the backend; regenerated via `pnpm --filter @lovejoin/backend run
# docs:openapi` and served live at /docs by the running server.
offchain/docs/
backend/openapi.json

# Generated artifacts kept out of source control until bootstrap commits them deliberately.
# addresses.json IS tracked once a network has been bootstrapped — the canonical
# protocol identifiers (NFT policy id, reference UTxO ref, script hashes) live there.
artifacts/test/*.plutus
artifacts/preprod/*.plutus
artifacts/test/blueprint.json
artifacts/preprod/blueprint.json

# Bootstrap intermediates — per-run tx state from cardano-cli, never canonical.
artifacts/*/*.tx
artifacts/*/*.txraw
artifacts/*/*.cert
artifacts/*/*.utxo.json
artifacts/*/*.hash
artifacts/*/blueprint.json
artifacts/*/reference_datum.json
artifacts/*/empty-redeemer.json
artifacts/*/unit-datum.json
artifacts/*/one_shot_mint.json
artifacts/*/mix_logic.json
artifacts/*/mix_box.json
artifacts/*/fee_contract.json
artifacts/*/tmp/

