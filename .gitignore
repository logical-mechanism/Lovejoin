node_modules/
dist/
build/
.cache/
.pnpm-store/

# TypeScript
*.tsbuildinfo

# Vite / UI
ui/dist/
ui/.vite/

# Aiken
contracts/build/
contracts/.build/
contracts/plutus.json

# Rust — Cargo.lock IS committed for reproducible KAT cross-checks
# (see docs/spec/12-build-guide.md §"Reproducibility").
crypto/ref/target/

# Local secrets / env
.env
.env.local
*.skey
*.vkey

# Bootstrap wallets — recommended location for the per-network wallet files
# (payment.skey/vkey, payment.addr) used by infra/bootstrap/*.sh. The bootstrap
# scripts only ever read these via env vars, but keeping the conventional path
# gitignored avoids accidents.
infra/bootstrap/wallets/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test artifacts
coverage/
playwright-report/
test-results/

# Generated artifacts kept out of source control until bootstrap commits them deliberately.
# addresses.json IS tracked once a network has been bootstrapped — the canonical
# protocol identifiers (NFT policy id, reference UTxO ref, script hashes) live there.
artifacts/test/*.plutus
artifacts/preprod/*.plutus
artifacts/test/blueprint.json
artifacts/preprod/blueprint.json

