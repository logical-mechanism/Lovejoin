# Lovejoin local secrets / runtime config.
#
# Copy this file to `.env` (gitignored) and fill in your own values. The
# Makefile targets (`make deposit`, `make withdraw`, `make integration-test`)
# load it automatically via Node 22's --env-file. The CLI does the same when
# invoked through `make cli` — direct `node` invocations need to pass
# `--env-file=.env` themselves.
#
# Nothing in this file is checked into git.

# ----- Network --------------------------------------------------------------
# Which Cardano network to target. preprod is the canonical pre-mainnet test
# network and the only one with a Lovejoin bootstrap deployed.
LOVEJOIN_NETWORK=preprod

# Path to the bootstrap output. Defaults to ./artifacts/<network>/addresses.json.
# Override only if you keep artifacts somewhere unusual.
# LOVEJOIN_ADDRESSES=./artifacts/preprod/addresses.json

# ----- Blockfrost -----------------------------------------------------------
# Free API key from https://blockfrost.io. Per-network — set the right one
# for LOVEJOIN_NETWORK above. The integration tests + CLI both look these up
# by network name.
BLOCKFROST_PROJECT_ID_PREPROD=
# BLOCKFROST_PROJECT_ID_PREVIEW=
# BLOCKFROST_PROJECT_ID_MAINNET=

# ----- Wallet credentials ---------------------------------------------------
# Pick ONE of the two wallet sources below.
#
# (a) cardano-cli payment skey hex. The hex is the `cborHex` field of a
# payment.skey JSON file; extract with:
#     jq -r .cborHex /path/to/payment.skey
# It looks like 5820XXXXXXXX… (5820 prefix + 32 bytes).
#
# Optional: LOVEJOIN_STAKE_SKEY for wallets using a base address. Without it
# the SDK derives the enterprise address (no staking part).
LOVEJOIN_PAYMENT_SKEY=
# LOVEJOIN_STAKE_SKEY=

# (b) BIP-39 mnemonic — 24 words, space- or comma-separated.
# LOVEJOIN_MNEMONIC="word1 word2 word3 ... word24"

# ----- Browser-wallet (CIP-30) ----------------------------------------------
# Browser wallet selection (Lace, Eternl, Nami, …) is a UI-runtime concern,
# not an env var. The UI will surface a wallet picker; the SDK's
# `connectBrowserWallet(name)` then does the CIP-30 handshake.

# ----- Backend (M5 indexer + REST API) --------------------------------------
# Read by backend/src/config.ts when you run `make backend-dev` or the Docker
# image. Required only if you're running the self-hosted indexer; the SDK
# itself uses Blockfrost (above).
NETWORK=preprod
PORT=3001
HOST=0.0.0.0
# WebSocket URL for an ogmios v6 node. Reachable Preprod ogmios looks like:
#   ws://<host>:1337
# (or wss:// if behind TLS). The backend health-checks ogmios at startup and
# refuses to bind without it.
OGMIOS_URL=ws://localhost:1337
# Postgres URL for cardano-db-sync. Used for /history/:address and (later)
# bulk initial-sync. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Common stock-image creds are USER=cexplorer DB=cexplorer; the password is
# whatever the operator set in the db-sync deployment. Leave blank to disable
# /history (the backend treats it as optional).
DBSYNC_URL=
# Path to the bootstrap-produced addresses.json. Defaults to
# ./artifacts/<NETWORK>/addresses.json — only override if you keep it
# elsewhere.
# ADDRESSES_PATH=./artifacts/preprod/addresses.json
# Comma-separated CORS origin allowlist (or * to permit any). Tighten for
# production deployments.
CORS_ORIGINS=*
# Per-IP rate limit, requests per minute. Generous default for dev.
RATE_LIMIT_PER_MIN=600

# ----- UI (Vite) ------------------------------------------------------------
# ui/vite.config.ts sets `envDir: ".."` so Vite reads VITE_* keys from this
# file. Vite only exposes VITE_-prefixed keys to client code — non-VITE
# entries above are ignored by the bundler. Values are baked into the
# static bundle at `pnpm --filter ui build`, so use *public-only* keys
# (a Blockfrost project id is rate-limited but isn't a secret).

# preprod | preview | mainnet
VITE_NETWORK=preprod

# Local backend (the M5 indexer at `make backend-dev`). Set to "" to bypass
# the backend and query Blockfrost directly.
VITE_BACKEND_URL=http://localhost:3001

# Blockfrost project id mirrored from BLOCKFROST_PROJECT_ID_PREPROD up top
# (Vite needs the VITE_ prefix to expose it).
VITE_BLOCKFROST_PROJECT_ID=

# Collateral provider — defaults to giveme.my; override only if running
# your own provider.
VITE_COLLATERAL_ENDPOINT=https://giveme.my
