# Lovejoin bootstrap environment.
#
# Copy this file to infra/bootstrap/.env and fill in the required fields.
# The actual .env is gitignored so you can keep the live values local.
#
# Every script under infra/bootstrap/ sources .env automatically at startup,
# so once this file is in place you don't have to `export` anything per shell.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Which network to target. preprod | preview. (mainnet is gated by spec OQ-Y.)
NETWORK=preprod
TESTNET_MAGIC=1

# Path to a synced cardano-node socket. cardano-cli's transaction build / submit
# / query commands all need this.
CARDANO_NODE_SOCKET_PATH=/path/to/preprod-node.socket

# ---------------------------------------------------------------------------
# Optional — overrides for the conventional file layout
# ---------------------------------------------------------------------------

# Wallet address. Default reads infra/bootstrap/wallets/payment.<network>.addr.
# BOOTSTRAP_ADDR=addr_test1...

# Payment signing key. Default infra/bootstrap/wallets/payment.skey.
# PAYMENT_SKEY=infra/bootstrap/wallets/payment.skey

# ---------------------------------------------------------------------------
# Optional — run.sh polling
# ---------------------------------------------------------------------------

# Per-stage confirmation timeout in seconds. Default 300 (5 minutes).
# CONFIRMATION_TIMEOUT_S=300

# ---------------------------------------------------------------------------
# Optional — prep-utxos.sh split sizes (lovelace)
# ---------------------------------------------------------------------------

# Increase if your reference scripts grow past ~5 KiB total, or decrease if
# you're testing with smaller validators.
# STAGE1_LOVELACE=85000000
# COLLATERAL_LOVELACE=10000000
# SEED_LOVELACE=7000000
# STAGE3_LOVELACE=45000000

# ---------------------------------------------------------------------------
# Optional — per-stage tuning
# ---------------------------------------------------------------------------

# Lovelace at the reference UTxO (02-mint-and-lock). Default 5_000_000.
# LOCKED_LOVELACE=5000000

# Lovelace per ref-script output (01-publish-and-register). Default 25_000_000.
# REF_PUBLISH_LOVELACE=25000000

# Lovelace per fee shard (03-fund-fee-contract). Default max_fee_per_mix * 5.
# SHARD_LOVELACE=4000000
