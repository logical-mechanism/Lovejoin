# Lovejoin UI build-time configuration.
#
# Self-hosters: copy this file to ui/.env (or .env.local) and edit before
# `pnpm --filter ui build`. The values are baked into the static bundle —
# they ship to every visitor, so use *public* keys only (Blockfrost has a
# per-project rate limit but keys are not secrets in the OWASP sense).
#
# The production UI shows zero config UI to end users. Developers can
# unlock an overrides panel at runtime by appending `?advanced=1` to any
# URL — overrides are written to localStorage and survive reloads on that
# browser only.

# Network: preprod | preview | mainnet. Defaults to preprod.
VITE_NETWORK=preprod

# Backend URL (the M5 indexer). When set the UI reads pool size + indexer
# lag from it; when blank the UI falls back to direct chain queries via
# the Blockfrost project below.
VITE_BACKEND_URL=

# Blockfrost project ID for the configured network. Required even when a
# backend is configured — the UI submits txs through Blockfrost and reads
# wallet UTxOs directly. Get a free key at https://blockfrost.io.
VITE_BLOCKFROST_PROJECT_ID=

# Collateral provider endpoint for Mix txs. Defaults to giveme.my, the
# canonical service in docs/spec/01-protocol.md §"Collateral provider".
# Override only if running your own provider.
VITE_COLLATERAL_ENDPOINT=https://giveme.my
