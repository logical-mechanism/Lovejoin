{
  "name": "@lovejoin/ui",
  "version": "0.0.0",
  "description": "Lovejoin UI — React 19 + Vite + Tailwind v4 + react-i18next.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "dev": "vite",
